{
  "compilerOptions": {
    /* Padrões de Compilação */
    "target": "es2016",
    "module": "commonjs",
    "lib": ["es2016"],
    "rootDir": "./",
    "outDir": "./build",

    /* Configuração de Caminhos (Substitui o baseUrl) */
    "paths": {
      "@config/*": ["./src/config/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"]
    },

    /* Decoradores (importante para TypeORM/Inversify) */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Interoperabilidade e Tipagem */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "typeRoots": ["./node_modules/@types", "./src/@types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "**/*.spec.ts"]
}
